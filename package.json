{
  "name": "bodrum-estate",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev --hostname localhost",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "firebase:deploy": "firebase deploy --only firestore:rules,firestore:indexes",
    "emulators": "firebase emulators:start"
  },
  "dependencies": {
    "cloudinary": "^2.9.0",
    "clsx": "2.1.1",
    "firebase": "11.1.0",
    "firebase-admin": "13.0.2",
    "framer-motion": "11.15.0",
    "lucide-react": "0.468.0",
    "next": "15.1.3",
    "next-intl": "3.26.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.54.2",
    "resend": "4.1.1",
    "tailwind-merge": "2.5.5",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "dotenv": "16.4.7",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.3",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
